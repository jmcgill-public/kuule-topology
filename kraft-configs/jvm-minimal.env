# Minimal JVM settings for Kafka
# Target: 64MB heap per broker

# Heap size (absolute minimum)
KAFKA_HEAP_OPTS="-Xms64m -Xmx64m"

# GC tuning (prefer low pause over throughput)
KAFKA_JVM_PERFORMANCE_OPTS="-XX:+UseG1GC -XX:MaxGCPauseMillis=20 -XX:InitiatingHeapOccupancyPercent=35 -XX:G1HeapRegionSize=16M"

# Reduce metaspace (we're not loading many classes)
KAFKA_JVM_PERFORMANCE_OPTS="$KAFKA_JVM_PERFORMANCE_OPTS -XX:MetaspaceSize=32m -XX:MaxMetaspaceSize=64m"

# Disable unnecessary features
KAFKA_JVM_PERFORMANCE_OPTS="$KAFKA_JVM_PERFORMANCE_OPTS -XX:+ExitOnOutOfMemoryError -XX:-UseBiasedLocking"

# JMX for metrics (lightweight)
KAFKA_JMX_OPTS="-Dcom.sun.management.jmxremote -Dcom.sun.management.jmxremote.authenticate=false -Dcom.sun.management.jmxremote.ssl=false"
